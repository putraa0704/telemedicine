{
    "version": 2,
    "framework": null,
    "outputDirectory": "public/dist",
    "functions": {
        "api/server.php": { "runtime": "vercel-php@0.9.0" }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.php?__vc_path=api/$1"
        },
        {
            "source": "/dist/(.*)",
            "destination": "/public/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/server.php?__vc_path=$1"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "",
        "VIEW_COMPILED_PATH": "/tmp",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
