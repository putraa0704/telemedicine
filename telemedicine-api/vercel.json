{
    "version": 2,
    "framework": null,
    "outputDirectory": "public/dist",
    "functions": {
        "api/server.php": { "runtime": "vercel-php@0.9.0" }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.php?__vc_path=api/$1"
        },
        {
            "source": "/dist/(.*)",
            "destination": "/public/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/server.php?__vc_path=$1"
        }
    ],
    "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://your-app.vercel.app",
    "VIEW_COMPILED_PATH": "/tmp",
    "CACHE_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "b1yxoebjomru8eutpefd-mysql.services.clever-cloud.com",
    "DB_PORT": "3306",
    "DB_DATABASE": "b1yxoebjomru8eutpefd",
    "DB_USERNAME": "uu1pvtlrzuqckrdi",
    "DB_PASSWORD": "vU9y3DXYWsqmRKAKFdDv",
    "MYSQL_ATTR_SSL_CA": "/etc/ssl/certs/ca-certificates.crt"
}
}
