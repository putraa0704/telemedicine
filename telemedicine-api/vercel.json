{
    "version": 2,
    "framework": null,
    "outputDirectory": "public/dist",
    "functions": {
        "api/server.php": { "runtime": "vercel-php@0.9.0" }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.php?__vc_path=/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/server.php?__vc_path=/$1"
        }
    ]
}
