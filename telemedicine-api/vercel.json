{
    "version": 2,
    "framework": null,
    "outputDirectory": "public/dist",
    "functions": {
        "api/server.php": { "runtime": "vercel-php@0.9.0" }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/server.php?__vc_path=/api/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/api/server.php?__vc_path=/:path*"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "VIEW_COMPILED_PATH": "/tmp",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "CACHE_DRIVER": "array",
        "QUEUE_CONNECTION": "sync"
    }
}