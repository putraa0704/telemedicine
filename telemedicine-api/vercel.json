{
    "version": 2,
    "framework": null,
    "outputDirectory": "public/dist",
    "functions": {
        "api/server.php": { "runtime": "vercel-php@0.7.4" }
    },
    "rewrites": [
        {
            "source": "/dist/(.*)",
            "destination": "/public/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/server.php?__vc_path=$1"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "",

        "APP_CONFIG_CACHE": "/tmp/config-v2.php",
        "APP_EVENTS_CACHE": "/tmp/events-v2.php",
        "APP_PACKAGES_CACHE": "/tmp/packages-v2.php",
        "APP_ROUTES_CACHE": "/tmp/routes-v2.php",
        "APP_SERVICES_CACHE": "/tmp/services-v2.php",
        "VIEW_COMPILED_PATH": "/tmp",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
